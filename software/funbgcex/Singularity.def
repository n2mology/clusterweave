Bootstrap: docker
From: ubuntu:22.04

%labels
    Author lattice
    Tool funbgcex+diamond+hmmer
    Base ubuntu:22.04

%environment
    export PATH=/opt/venv/bin:/usr/local/bin:$PATH
    export TMPDIR=/var/tmp
    export PIP_DISABLE_PIP_VERSION_CHECK=1

%post
    set -eu
    export DEBIAN_FRONTEND=noninteractive
    export TMPDIR=/var/tmp
    mkdir -p /var/tmp /usr/local/bin

    apt-get update
    apt-get install -y --no-install-recommends \
        bash ca-certificates curl wget unzip \
        python3 python3-venv python3-pip \
        build-essential \
        hmmer
    rm -rf /var/lib/apt/lists/*

    DIAMOND_VERSION=2.1.9
    mkdir -p /var/tmp/diamond
    cd /var/tmp/diamond
    curl -L -o diamond.tar.gz "https://github.com/bbuchfink/diamond/releases/download/v${DIAMOND_VERSION}/diamond-linux64.tar.gz"
    tar -xzf diamond.tar.gz
    install -m 0755 diamond /usr/local/bin/diamond
    cd /
    rm -rf /var/tmp/diamond

    python3 -m venv /opt/venv
    /opt/venv/bin/python -m pip install --upgrade pip setuptools wheel
    /opt/venv/bin/python -m pip install --no-cache-dir funbgcex==1.0.1

    cat > /usr/local/bin/run_funbgcex <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
export TMPDIR=/var/tmp
INDIR="$1"
OUTDIR="${2:-./funbgcex_out}"
WORKERS="${3:-2}"
exec funbgcex "${INDIR}" "${OUTDIR}" --workers "${WORKERS}"
EOF
    chmod +x /usr/local/bin/run_funbgcex

%runscript
    exec /bin/bash "$@"

%help
    Container bundles:
      - funbgcex 1.0.1
      - DIAMOND 2.1.9
      - HMMER
    Usage:
      singularity exec funbgcex_bundle.sif run_funbgcex input_dir outdir 2
