Bootstrap: docker
From: nextgenusfs/funannotate:v1.8.17

%labels
    Author lattice
    Tool funannotate
    Base nextgenusfs/funannotate:v1.8.17
    ClusterWeaveSlice 74

%environment
    export FUNANNOTATE_DB=/opt/databases
    export PATH=/venv/bin:$PATH

%files
    install_busco_db.py /opt/clusterweave-install-busco-db.py
    busco_cache /opt/clusterweave-busco-cache

%post
    set -eu
    export FUNANNOTATE_DB="${FUNANNOTATE_DB:-/opt/databases}"
    FUNANNOTATE_BUSCO_DBS="${FUNANNOTATE_BUSCO_DBS:-ascomycota basidiomycota microsporidia dikarya fungi}"
    if [ ! -x /venv/bin/python ] && [ -x /venv/bin/python3 ]; then
      ln -s python3 /venv/bin/python
    fi
    if [ ! -x /venv/bin/python ] && command -v python3 >/dev/null 2>&1; then
      ln -s "$(command -v python3)" /venv/bin/python
    fi
    test -x /venv/bin/python
    if [ ! -x /usr/local/bin/python ]; then
      ln -s /venv/bin/python /usr/local/bin/python
    fi
    test -x /usr/local/bin/python
    mkdir -p "${FUNANNOTATE_DB}"
    install_from_cache() {
      db="$1"
      for tarball in "/opt/clusterweave-busco-cache/${db}.tar.gz" "/opt/clusterweave-busco-cache/${db}_odb9.tar.gz"; do
        [ -s "${tarball}" ] || continue
        root="$(tar -tzf "${tarball}" | awk -F/ 'NR==1 {print $1; exit}')"
        [ -n "${root}" ] || return 1
        rm -rf "${FUNANNOTATE_DB:?}/${db}" "${FUNANNOTATE_DB}/${root}"
        tar -zxf "${tarball}" -C "${FUNANNOTATE_DB}"
        if [ "${root}" != "${db}" ]; then mv "${FUNANNOTATE_DB}/${root}" "${FUNANNOTATE_DB}/${db}"; fi
        return 0
      done
      return 1
    }
    for db in ${FUNANNOTATE_BUSCO_DBS}; do
      if install_from_cache "${db}"; then
        echo "Installed ${db} BUSCO DB from local cache"
      else
        attempt=1
        until /venv/bin/python /opt/clusterweave-install-busco-db.py \
          --database "${FUNANNOTATE_DB}" \
          --cache-dir /opt/clusterweave-busco-cache \
          --db "${db}"; do
          if [ "${attempt}" -ge 3 ]; then exit 1; fi
          attempt=$((attempt + 1))
          sleep 5
        done
      fi
    done
    for db in ${FUNANNOTATE_BUSCO_DBS}; do
      test -d "${FUNANNOTATE_DB}/${db}/hmms"
      find "${FUNANNOTATE_DB}/${db}/hmms" -type f -print -quit | grep -q .
    done

%runscript
    exec /bin/bash "$@"

%help
    ClusterWeave funannotate v1.8.17 runtime with selected old funannotate-compatible
    BUSCO lineage databases baked into FUNANNOTATE_DB at image/SIF build time.
