# Generic example profile for a ClusterWeave project.
# Copy this file only if you want a reusable per-project env file.

PROJECT_NAME=my_project
# ACCESSIONS_FILE=/absolute/path/to/accessions_my_project.txt
# TARGET_GENOME=Genus_species_Strain
# ECOLOGY_FIELD=ecofun_primary
# FOCUS_ECOLOGY_LABEL=

# Optional overrides for an external shared workspace:
# PROJECTS_ROOT=/path/to/Projects
# DATA_ROOT=/path/to/Projects/Data
# SOFTWARE_ROOT=/path/to/Projects/Software
