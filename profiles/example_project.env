# Generic example profile for a ClusterWeave project.
# Copy this file only if you want a reusable per-project env file.

PROJECT_NAME=my_project
# Choose fungi, bacteria, or both. Authoritative NCBI taxonomy still controls
# per-accession routing and rejects scope mismatches.
ANALYSIS_SCOPE=both
# ACCESSIONS_FILE=/absolute/path/to/accessions_my_project.txt
# TARGET_GENOME=Genus_species_Strain
# ECOLOGY_FIELD=ecofun_primary
# FOCUS_ECOLOGY_LABEL=

# Optional annotation fan-out controls:
# PIPELINE_RESOURCE_MODE=conservative
# Use "auto" only when you want ClusterWeave to derive a bounded local plan.
# GENOME_PARALLELISM=1
# ANNO_CPUS=4
# Whole-genome funannotate/BRAKER3 CPUs per concurrently processed genome.
# WORKERS=2
# ANTISMASH_RECORD_PARALLELISM=1
# ANTISMASH_SHARD_CPUS=
# When ANTISMASH_SHARD_CPUS is unset, it defaults to max(1, CPUS / ANTISMASH_RECORD_PARALLELISM).
# ANTISMASH_LEGACY_CPUS=
# When unset, legacy single-run antiSMASH keeps the normal CPUS value.
# ANTISMASH_RETAIN_SHARD_WORK=0
# Keep this at 0 for normal runs so successful shard work is compacted promptly.

# The dependency-light taxonomy/BGC/GCF figure is a normal result.
# RUN_TAXON_TREE_FIGURE=1
# PHYLOGENY_MAX_VISIBLE_ARCS=80
# Sequence-inferred trees and cross-kingdom context are optional and disabled.
# Build the pinned runtime explicitly before enabling either profile.
# RUN_PHYLOGENY=0
# PHYLOGENY_REQUIRED=0
# PHYLOGENY_AUTO_PREPARE=1  # set 0 only with an explicit families.tsv override
# PHYLOGENY_CPUS=1
# PHYLOGENY_PARALLELISM=1
# PHYLOGENY_MAX_FAMILIES=10
# PHYLOGENY_MAX_SEQUENCES_PER_FAMILY=250
# PHYLOGENY_MAX_INPUT_BYTES=262144000
# PHYLOGENY_TIMEOUT_SECONDS=7200
# RUN_CROSS_KINGDOM_EVIDENCE=0

# Optional overrides for an external shared workspace:
# PROJECTS_ROOT=/path/to/Projects
# DATA_ROOT=/path/to/Projects/data
# SOFTWARE_ROOT=/path/to/Projects/software
