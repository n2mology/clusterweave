# Frozen-profile template for the ClusterWeave v1.0.0 release run.
#
# Source this from the repository root:
#
#   set -a
#   source profiles/release_v1.0.0.env
#   set +a
#   bash run_clusterweave.sh
#
# This profile keeps the normal source URIs visible for provenance but disables
# automatic downloads/pulls for mutable runtime artifacts. Prepopulate software/
# first, then compare data/results/<project>/reproducibility/external_artifacts.tsv.
# For resources whose upstream URL is mutable, the local checksum table is the
# frozen run record; this profile prevents replacing those bytes accidentally.

PROJECT_DIR="${PROJECT_DIR:-$(pwd -P)}"
PROJECT_NAME=clusterweave_v1_0_0
DATA_ROOT="${DATA_ROOT:-${PROJECT_DIR}/data}"
SOFTWARE_ROOT="${SOFTWARE_ROOT:-${PROJECT_DIR}/software}"
RESULTS_ROOT="${RESULTS_ROOT:-${DATA_ROOT}/results/${PROJECT_NAME}}"

RUN_STAGE_ANNOTATION=1
RUN_STAGE_BIGSCAPE=1
RUN_STAGE_SUMMARY=1
RUN_STAGE_CLINKER=auto
CLINKER_MODE=auto
RUN_CLINKER=1
CAPTURE_EXTERNAL_ARTIFACTS=1
ANALYSIS_SCOPE=both

# Stage 1: annotation and BGC detection
ANTISMASH_IMAGE_URI=docker://antismash/standalone:8.0.4
ANTISMASH_SIF="${ANTISMASH_SIF:-${SOFTWARE_ROOT}/antismash/antismash_standalone.sif}"
FUNBGCEX_VERSION=1.0.1
FUNBGCEX_SIF="${FUNBGCEX_SIF:-${SOFTWARE_ROOT}/funbgcex/funbgcex_bundle.sif}"
FUNBGCEX_DEF="${FUNBGCEX_DEF:-${PROJECT_DIR}/software/funbgcex/Singularity.def}"
FUNBGCEX_DOCKERFILE="${FUNBGCEX_DOCKERFILE:-${PROJECT_DIR}/software/funbgcex/Dockerfile}"
FUNBGCEX_BUILD_SCRIPT="${FUNBGCEX_BUILD_SCRIPT:-${PROJECT_DIR}/software/funbgcex/build_funbgcex_sif.sh}"
FUNANNOTATE_IMAGE_URI=docker://nextgenusfs/funannotate:v1.8.17
FUNANNOTATE_SIF="${FUNANNOTATE_SIF:-${SOFTWARE_ROOT}/funannotate/funannotate_v1.8.17.sif}"
BRAKER_IMAGE_URI=docker://teambraker/braker3:v3.0.7.6@sha256:5f8b3c508a9fe1bbc2e9a74dcc013eeed82f91dd5945adca7823514d9c8aecf8
BRAKER3_ENABLED=0

# Stage 2: BiG-SCAPE and reference resources
BIGSCAPE_SIF_SOURCE=docker://ghcr.io/medema-group/big-scape:2.0.0-beta.6
BIGSCAPE_SIF_PATH="${BIGSCAPE_SIF_PATH:-${SOFTWARE_ROOT}/big_scape/bigscape_2.0.0-beta.6.sif}"
PFAM_URL=https://ftp.ebi.ac.uk/pub/databases/Pfam/current_release/Pfam-A.hmm.gz
PFAM_HMM="${PFAM_HMM:-${SOFTWARE_ROOT}/big_scape/resources/pfam/Pfam-A.hmm}"
FASTTREE_URL=https://raw.githubusercontent.com/morgannprice/fasttree/29c5e62fbcd93230ee325f9c6a17b81f00e3c72a/FastTree
FASTTREE_SHA256=55a9d997813aae2208bd4c2081bfa690e0ecdba2d6c491805d8689415c43e38e
FASTTREE_VERSION=2.2.0
FASTTREE_HOST="${FASTTREE_HOST:-${SOFTWARE_ROOT}/big_scape/bin/fasttree}"
MIBIG_VERSION_DEFAULT=4.0
MIBIG_CACHE="${MIBIG_CACHE:-${SOFTWARE_ROOT}/big_scape/resources/mibig_cache}"

# Stage 4: clinker
CLINKER_CONTAINER_TAG=0.0.32--pyhdfd78af_0
CLINKER_SIF_SOURCE=docker://quay.io/biocontainers/clinker-py:${CLINKER_CONTAINER_TAG}
CLINKER_SIF_PATH="${CLINKER_SIF_PATH:-${SOFTWARE_ROOT}/clinker/clinker-py_${CLINKER_CONTAINER_TAG}.sif}"

# Reproducibility guardrails: use prepopulated artifacts for the release run.
AUTO_PULL_IMAGES=never
AUTO_BUILD_FUNBGCEX_SIF=0
AUTO_PULL_BIGSCAPE_SIF=0
AUTO_DOWNLOAD_PFAM=0
AUTO_DOWNLOAD_FASTTREE=0
MIBIG_AUTO_DOWNLOAD=0
INSTALL_CLINKER_SIF=0

# Core taxon tree is dependency-light. Sequence inference and cross-kingdom
# evidence remain explicit, bounded opt-ins for the release profile.
RUN_TAXON_TREE_FIGURE=1
RUN_PHYLOGENY=0
PHYLOGENY_REQUIRED=0
RUN_CROSS_KINGDOM_EVIDENCE=0
