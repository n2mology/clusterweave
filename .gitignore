# Language and tooling caches.
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.coverage
coverage.xml
htmlcov/
.DS_Store
.venv/
venv/

# Dependencies and generated test reports.
node_modules/
/test-results/
/playwright-report/
/blob-report/
/coverage/

# Local runtime configuration and credentials.
/.env
/.env.*
!/.env.example
!/.env.sample
/config/local.env
/credentials/
/secrets/
/private/
*.pem
*.key
*.p12
*.pfx
id_rsa*
id_ed25519*
known_hosts
authorized_keys

# Logs, temporary files, editor state, and backups.
*.log
*.tmp
*.bak
*.backup
*.orig
*.rej
*.swp
*.swo
*~

# Runtime uploads, workspaces, queues, and results; retain only public placeholders.
/data/**
!/data/genomes/
!/data/genomes/fungi/
!/data/genomes/fungi/.gitkeep
!/data/results/
!/data/results/.gitkeep

software/**
!software/.gitkeep
!software/funbgcex/
software/funbgcex/**
!software/funbgcex/build_funbgcex_sif.sh
!software/funbgcex/Dockerfile
!software/funbgcex/Singularity.def
!software/funannotate/
