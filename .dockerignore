# Source-control metadata.
.git/
.github/
.gitignore

# Dependencies and tooling caches.
node_modules/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.ipynb_checkpoints/
.DS_Store

# Local runtime configuration and credentials.
.env
.env.*
!.env.example
!.env.sample
config/local.env
credentials/
secrets/
private/
*.pem
*.key
*.p12
*.pfx
id_rsa*
id_ed25519*
known_hosts
authorized_keys

# Generated reports and runtime data.
test-results/
playwright-report/
blob-report/
coverage/
htmlcov/
.coverage
coverage.xml
tmp/
results/
logs/
data

# Downloaded software stays outside image contexts; retain build recipes.
software/*
!software/funbgcex/
!software/funbgcex/Dockerfile
!software/funbgcex/Singularity.def
!software/funbgcex/build_funbgcex_sif.sh
!software/funannotate/
!software/funannotate/Dockerfile
!software/funannotate/Singularity.def
!software/funannotate/build_funannotate_sif.sh
!software/funannotate/install_busco_db.py
!software/funannotate/README.md
!software/funannotate/busco_cache/
software/funannotate/busco_cache/*
!software/funannotate/busco_cache/.gitkeep
!software/phylogeny/
!software/phylogeny/Dockerfile
!software/phylogeny/Singularity.def
!software/phylogeny/build_phylogeny_image.sh
!software/phylogeny/build_phylogeny_sif.sh
!software/phylogeny/compare_gene_tree_taxonomy.py

# Logs, temporary files, backups, and generated databases.
*.log
*.tmp
*.bak
*.backup
*.orig
*.rej
*.swp
*.swo
*~
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
