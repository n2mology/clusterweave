# Default ClusterWeave configuration

PROJECT_NAME=clusterweave
# PROJECT_NAME is the namespace for project-specific genome and result folders.
# Use a different PROJECT_NAME for each study you want to keep separate.

# First manual input:
# ACCESSIONS_FILE defaults to <repo>/accessions.txt
# Use prepare_genomes_from_accessions.sh to populate Data/Genomes/Fungi/<project-name>/

# Standalone repository layout
# PROJECTS_ROOT defaults to the repository root.
# Override these if you keep Data/ and Software/ elsewhere.
# DATA_ROOT=
# SOFTWARE_ROOT=
# RESULTS_ROOT=

# Optional reviewer-facing target genome.
# TARGET_GENOME=
# CLINKER_MODE=auto
# RUN_CLINKER=1
# Set RUN_CLINKER=0 to stage clinker panels without executing clinker.
# ATLAS_MIN_RECORDS=2
# RUN_STAGE_ANNOTATION=1
# RUN_STAGE_BIGSCAPE=1
# RUN_STAGE_SUMMARY=1
# RUN_STAGE_CLINKER=auto
# CAPTURE_EXTERNAL_ARTIFACTS=1
# Writes Data/Results/<project-name>/reproducibility/external_artifacts.tsv after canonical runs.

# Ecology handling
# RUN_ECOLOGY_ANALYSIS=0
# ECOLOGY_FIELD=ecofun_primary
# FOCUS_ECOLOGY_LABEL=
# AUTO_NORMALIZE_METADATA=1
# ACCESSIONS_MAP=
# METADATA_TSV=
# METADATA_TEMPLATE_TSV=
# Static repo header template: config/metadata_template.tsv

# Clinker panel display defaults
# CLINKER_SCALE_FACTOR=12
# CLINKER_VERTICAL_SPACING=70
# CLINKER_ALIGN_LABELS=1
# CLINKER_HIDE_COORDINATES=1
# CLINKER_SHOW_GENE_LABELS=1
# CLINKER_USE_GROUP_COLOUR=1
# CLINKER_SHOW_LINK_LABELS=1

# Figure rendering
# R_BIN=Rscript
# On WSL/Git Bash, run_figures.sh also tries common Windows Rscript.exe locations automatically.

# Tool/runtime toggles
# ENGINE=apptainer
# CPUS=6
# THREADS=6
# FORCE=0
# AUTO_PULL_IMAGES=always
# ANTISMASH_IMAGE_URI=docker://antismash/standalone:8.0.4
# AUTO_BUILD_FUNBGCEX_SIF=1
# FUNBGCEX_DEF=
# FUNBGCEX_DOCKERFILE=
# FUNBGCEX_BUILD_SCRIPT=
# FUNBGCEX_BOOTSTRAP=0
# FUNBGCEX_SIF=
# FUNBGCEX_VERSION=1.0.1
# AUTO_PULL_BIGSCAPE_SIF=1
# AUTO_DOWNLOAD_PFAM=1
# AUTO_DOWNLOAD_FASTTREE=1
# MIBIG_AUTO_DOWNLOAD=1
# AUTO_PULL_NPLINKER_SIF=1
# NPLINKER_BOOTSTRAP_ENV=1
