# Default ClusterWeave configuration

PROJECT_NAME=clusterweave
# PROJECT_NAME is the namespace for project-specific genome and result folders.
# Use a different PROJECT_NAME for each study you want to keep separate.

# First manual input:
# ACCESSIONS_FILE defaults to <repo>/accessions.txt
# Use prepare_genomes_from_accessions.sh to populate data/genomes/fungi/<project-name>/

# Standalone repository layout
# PROJECTS_ROOT defaults to the repository root.
# Override these if you keep data/ and software/ elsewhere.
# DATA_ROOT=
# SOFTWARE_ROOT=
# RESULTS_ROOT=

# Optional reviewer-facing target genome.
# TARGET_GENOME=
# CLINKER_MODE=auto
# RUN_CLINKER=1
# Set RUN_CLINKER=0 to stage clinker panels without executing clinker.
# ATLAS_MIN_RECORDS=2
# RUN_STAGE_ANNOTATION=1
# RUN_STAGE_BIGSCAPE=1
# RUN_STAGE_SUMMARY=1
# RUN_STAGE_CLINKER=auto
# CAPTURE_EXTERNAL_ARTIFACTS=1
# Writes data/results/<project-name>/reproducibility/external_artifacts.tsv after canonical runs.

# Ecology handling
# RUN_ECOLOGY_ANALYSIS=0
# ECOLOGY_FIELD=ecofun_primary
# FOCUS_ECOLOGY_LABEL=
# AUTO_NORMALIZE_METADATA=1
# ACCESSIONS_MAP=
# METADATA_TSV=
# METADATA_TEMPLATE_TSV=
# Static repo header template: config/metadata_template.tsv

# Clinker panel display defaults
# CLINKER_SCALE_FACTOR=12
# CLINKER_VERTICAL_SPACING=70
# CLINKER_ALIGN_LABELS=1
# CLINKER_HIDE_COORDINATES=1
# CLINKER_SHOW_GENE_LABELS=1
# CLINKER_USE_GROUP_COLOUR=1
# CLINKER_SHOW_LINK_LABELS=1

# Figure rendering
# R_BIN=Rscript
# On WSL/Git Bash, run_figures.sh also tries common Windows Rscript.exe locations automatically.
# RUN_BIGSCAPE_NETWORK_FIGURE=1
# BIGSCAPE_NETWORK_METADATA_TSV=
# BIGSCAPE_NETWORK_ANNOTATION_TABLE=
# BIGSCAPE_NETWORK_ECOLOGY_FIELD=ecofun_primary
# BIGSCAPE_NETWORK_FORMATS=svg,graphml
# BIGSCAPE_NETWORK_CATEGORY=mix
# BIGSCAPE_NETWORK_CLUSTERING_THRESHOLD=0.3
# BIGSCAPE_NETWORK_DISTANCE_THRESHOLD=
# BIGSCAPE_NETWORK_SIMILARITY_THRESHOLD=
# BIGSCAPE_NETWORK_MAX_NODES=0
# BIGSCAPE_NETWORK_MAX_COMPONENTS=0
# BIGSCAPE_NETWORK_INCLUDE_MIBIG_ONLY=0
# BIGSCAPE_NETWORK_CANVAS_WIDTH=1200
# RUN_TAXON_TREE_FIGURE=1
# PHYLOGENY_MAX_VISIBLE_ARCS=80

# Optional sequence inference is separate from the normal taxonomy figure.
# Keep these disabled unless a pinned image/SIF was prepared explicitly.
# RUN_PHYLOGENY=0
# PHYLOGENY_REQUIRED=0
# RUN_PHYLOGENY=1 explicitly enables bounded protein-family preparation from
# shortlisted cross-domain GCF antiSMASH regions. Set this to 0 only when a
# complete bounded families.tsv is supplied explicitly.
# PHYLOGENY_AUTO_PREPARE=1
# PHYLOGENY_CPUS=1
# PHYLOGENY_PARALLELISM=1
# PHYLOGENY_MAX_FAMILIES=10
# PHYLOGENY_MAX_SEQUENCES_PER_FAMILY=250
# PHYLOGENY_MAX_INPUT_BYTES=262144000
# PHYLOGENY_MAX_ALIGNMENT_BYTES=50000000
# PHYLOGENY_TIMEOUT_SECONDS=7200
# PHYLOGENY_RETAIN_SCRATCH=0
# PHYLOGENY_RUNTIME=auto
# PHYLOGENY_DOCKER_IMAGE=clusterweave-phylogeny:1.0.0
# PHYLOGENY_SIF_PATH=software/phylogeny/clusterweave_phylogeny_1.0.0.sif
# RUN_CROSS_KINGDOM_EVIDENCE=0
# Historical configuration aliases are fallback-only.

# Tool/runtime toggles
# ENGINE=apptainer
# CPUS=6
# THREADS=6
# PIPELINE_RESOURCE_MODE=conservative
# "conservative" honors explicit/manual targets within the job CPU budget.
# Local operators may opt in to "auto" to derive a cgroup-aware bounded plan.
# GENOME_PARALLELISM=1
# Concurrent genomes processed during annotation; keep this within the available job CPU and memory budget.
# ANNO_CPUS=4
# Native BRAKER3/funannotate CPUs for each whole-genome annotation lane.
# FUNANNOTATE_MIN_TRAINING_MODELS_FALLBACK=150
# Retry a structured BUSCO/AUGUSTUS insufficient-training failure only when at
# least this many BUSCO models validated. Runtime clamps operator values to the
# conservative 100..199 range below funannotate's default threshold of 200.
# WORKERS=2
# FunBGCeX workers per genome.
# ANTISMASH_RECORD_PARALLELISM=1
# Concurrent antiSMASH records within each genome. Values <=1 preserve the legacy single-run path.
# ANTISMASH_SHARD_CPUS=
# Optional CPUs per record shard; when unset, defaults to max(1, CPUS / ANTISMASH_RECORD_PARALLELISM).
# ANTISMASH_LEGACY_CPUS=
# Optional CPUs for one legacy antiSMASH run; when unset, defaults to CPUS. Public jobs set a per-genome cap.
# ANTISMASH_RETAIN_SHARD_WORK=0
# Successful shards are compacted under WORK_ROOT by default. Set to 1 only for short-lived debugging.
# FORCE=0
# AUTO_PULL_IMAGES=always
# ANTISMASH_IMAGE_URI=docker://antismash/standalone:8.0.4
# AUTO_BUILD_FUNBGCEX_SIF=1
# FUNBGCEX_DEF=
# FUNBGCEX_DOCKERFILE=
# FUNBGCEX_BUILD_SCRIPT=
# FUNBGCEX_BOOTSTRAP=0
# FUNBGCEX_SIF=
# FUNBGCEX_VERSION=1.0.1
# AUTO_PULL_BIGSCAPE_SIF=1
# AUTO_DOWNLOAD_PFAM=1
# AUTO_DOWNLOAD_FASTTREE=1
# MIBIG_AUTO_DOWNLOAD=1
# AUTO_PULL_NPLINKER_SIF=1
# NPLINKER_BOOTSTRAP_ENV=1

# Web submission and worker admission policy (compose host environment)
# CLUSTERWEAVE_MIN_FREE_DISK_GB=0
# CLUSTERWEAVE_PUBLIC_GENOME_PARALLELISM=1
# CLUSTERWEAVE_PUBLIC_ANTISMASH_RECORD_PARALLELISM=1
# CLUSTERWEAVE_PUBLIC_FUNANNOTATE_CPUS_PER_GENOME=4
# CLUSTERWEAVE_MAX_CONCURRENT_UPLOADS=2
# CLUSTERWEAVE_MAX_UPLOAD_BODY_OVERHEAD_MB=16
# CLUSTERWEAVE_PUBLIC_FUNBGCEX_WORKERS_PER_GENOME=2
# CLUSTERWEAVE_MAX_CPUS_PER_JOB=4
# WORKER_CONCURRENCY=1
# CLUSTERWEAVE_WORKER_CPU_LIMIT=4
# CLUSTERWEAVE_WORKER_PIDS_LIMIT=8192
# CLUSTERWEAVE_TOOL_DOCKER_CPUS=
# CLUSTERWEAVE_TOOL_DOCKER_MEMORY=
# CLUSTERWEAVE_TOOL_DOCKER_PIDS_LIMIT=4096
# Both local Compose profiles accept at most 4 CPUs per public job and cap the
# worker at 4 CPUs by default. Override both limits together to match the host.
# WORKER_CPU_BUDGET=auto
# WORKER_MEMORY_BUDGET_MB=auto
# WORKER_PENDING_RECOVERY_SECONDS=30
# WORKER_PENDING_RECOVERY_GRACE_SECONDS=60
# WORKER_MIN_FREE_DISK_GB=0
# WORKER_MEMORY_BASE_MB=1024
# WORKER_MEMORY_PER_GENOME_MB=2048
# WORKER_MEMORY_PER_ANTISMASH_SHARD_MB=2048
# WORKER_MEMORY_PER_ANNOTATION_CPU_MB=256
# WORKER_MEMORY_PER_FUNBGCEX_WORKER_MB=128
# WORKER_MEMORY_PHYLOGENY_BASE_MB=1024
# WORKER_MEMORY_PER_PHYLOGENY_CPU_MB=2048
# WORKER_MEMORY_SAFETY_FACTOR=1.25
# WORKER_MEMORY_MINIMUM_MB=2048
# Set explicit disk floors and calibrated budgets for hosted production. The
# zero disk-floor defaults preserve compatibility for small local workspaces.
