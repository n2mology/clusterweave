FROM python:3.11-slim

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY web/app.py /app/app.py
COPY bin/backfill_result_attestations.py /app/backfill_result_attestations.py
COPY web/bigscape_public_db.py /app/bigscape_public_db.py
COPY web/genbank_readiness.py /app/genbank_readiness.py
COPY web/job_store.py /app/job_store.py
COPY web/notifications.py /app/notifications.py
COPY web/public_results.py /app/public_results.py
COPY web/public_result_backend.py /app/public_result_backend.py
COPY web/public_result_http.py /app/public_result_http.py
COPY web/result_policy.py /app/result_policy.py
COPY web/result_attestation.py /app/result_attestation.py
COPY web/resource_policy.py /app/resource_policy.py
COPY web/runtime_capabilities.py /app/runtime_capabilities.py
COPY web/taxon_routing.py /app/taxon_routing.py
COPY web/static/ /app/static/
COPY web/entrypoint-web.sh /app/entrypoint.sh

RUN chmod +x /app/entrypoint.sh

RUN mkdir -p /data/uploads /data/jobs /databases/antismash /databases/pfam

EXPOSE 8080

ENV DATA_DIR=/data
ENV ANTISMASH_DB_DIR=/databases/antismash
ENV PFAM_DIR=/databases/pfam
ENV PORT=8080

ENTRYPOINT ["/app/entrypoint.sh"]
